{
  "name": "liquio-filestorage",
  "version": "0.1.0",
  "engines": {
    "node": "22"
  },
  "private": true,
  "main": "src/app.js",
  "license": "SEE LICENSE IN ../LICENSE.md",
  "scripts": {
    "start": "node src/app.js",
    "start:ts": "node -r ts-node/register src/app.ts",
    "build": "tsc",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:fix": "eslint \"**/*.{js,ts}\" --fix",
    "migration-up": "sequelize db:migrate",
    "migration-clear": "sequelize db:migrate:undo:all",
    "seed-up": "sequelize db:seed:all",
    "seed-clear": "sequelize db:seed:undo:all",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.18.1",
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "inquirer": "^8.2.6",
    "jsontoxml": "^1.0.1",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "mime-types": "^3.0.2",
    "moment": "^2.30.1",
    "multiconf": "^4.0.0",
    "pg": "^8.20.0",
    "sequelize": "^6.30.0",
    "sequelize-cli": "^6.6.5",
    "swagger-ui-express": "^5.0.1",
    "transliteration": "^2.6.1",
    "ua-en-translit": "^3.1.2",
    "xml2js": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^16.4.0",
    "jest": "^30.3.0",
    "nock": "^14.0.15",
    "proxyquire": "^2.1.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "semver": "7.5.4",
    "tough-cookie": "4.1.3",
    "form-data": "2.5.5"
  }
}
