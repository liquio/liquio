{
  "name": "liquio-manager",
  "version": "0.1.2",
  "engines": {
    "node": "22"
  },
  "private": true,
  "license": "SEE LICENSE IN ../LICENSE.md",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:ts": "node -r ts-node/register src/index.ts",
    "build": "tsc",
    "migration-generate": "sequelize migration:generate --name new-migration",
    "migration-up": "sequelize db:migrate",
    "migration-clear": "sequelize db:migrate:undo:all",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:fix": "eslint \"**/*.{js,ts}\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "axios": "^1.18.1",
    "ccolor": "^1.3.1",
    "express": "^5.2.1",
    "multiconf": "^4.0.0",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.3",
    "redis": "^5.12.1",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "xml2js": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "eslint": "^10.6.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "nock": "^14.0.15",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "semver": "7.5.4",
    "tough-cookie": "4.1.3",
    "form-data": "2.5.5"
  }
}
