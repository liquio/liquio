{
  "name": "liquio-gateway",
  "version": "0.1.2",
  "engines": {
    "node": "22"
  },
  "private": true,
  "license": "SEE LICENSE IN ../LICENSE.md",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:ts": "node -r ts-node/register src/index.ts",
    "build": "tsc",
    "migration-up": "./node_modules/.bin/sequelize db:migrate",
    "migration-clear": "./node_modules/.bin/sequelize db:migrate:undo:all",
    "lint": "eslint \"**/*.{js,ts}\"",
    "lint:fix": "eslint \"**/*.{js,ts}\" --fix",
    "test": "jest src",
    "test:watch": "jest src --watch",
    "test:cov": "jest src --coverage",
    "test:e2e": "jest tests"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "amqplib": "^0.10.9",
    "axios": "^1.15.2",
    "body-parser": "^1.20.3",
    "ccolor": "^1.3.1",
    "express": "^5.2.1",
    "isolated-vm": "^6.1.2",
    "jsonc-parser": "^3.2.0",
    "lodash": "^4.17.20",
    "lru-cache": "^10.4.3",
    "moment": "^2.29.4",
    "moment-business-days": "^1.2.0",
    "multiconf": "^4.0.0",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "redis": "^5.11.0",
    "sequelize": "^6.29.0",
    "sequelize-cli": "^6.6.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^11.13.0",
    "@testcontainers/rabbitmq": "^11.13.0",
    "@types/amqplib": "^0.10.8",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "debug": "^4.4.3",
    "eslint": "^10.2.1",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "portfinder": "^1.0.37",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "semver": "7.5.4",
    "tough-cookie": "4.1.3",
    "form-data": "2.5.5"
