{
  "name": "liquio-persist-link",
  "version": "0.1.4",
  "description": "Persist link",
  "main": "src/app.ts",
  "directories": {
    "lib": "src/lib"
  },
  "scripts": {
    "start": "ts-node --transpile-only src/app.ts",
    "start:prod": "node dist/src/app.js",
    "build": "tsc",
    "migration-up": "sequelize db:migrate --migrations-path ./migrations --config ./migrations-config.js",
    "lint": "eslint \"**/*.ts\" \"**/*.js\"",
    "lint:fix": "eslint \"**/*.ts\" \"**/*.js\" --fix",
    "test": "jest",
    "test:e2e": "jest --verbose test/*.e2e.spec.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "license": "SEE LICENSE IN ../LICENSE.md",
  "private": true,
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "axios": "^1.11.0",
    "body-parser": "^2.3.0",
    "ccolor": "^1.3.1",
    "express": "^5.2.1",
    "got": "^11.8.2",
    "handlebars": "^4.7.7",
    "html-pdf": "^3.0.1",
    "iconv-lite": "^0.6.3",
    "isolated-vm": "^5.0.4",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "multiconf": "^4.0.0",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "phantomjs-prebuilt": "^2.1.16",
    "prop-by-path": "^1.0.5",
    "qr-image": "^3.2.0",
    "request": "^2.88.0",
    "sequelize": "^6.29.0",
    "sequelize-cli": "^6.6.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "portfinder": "^1.0.37",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
